{
  "manifest_version": 3,
  "name": "ARGUS — Adaptive Risk & Generative Understanding System",
  "version": "2.0.0",
  "description": "Context-aware AI cybersecurity guardian. Deepfake detection, malicious URL blocking, phishing email scanning.",
  "permissions": [
    "storage",
    "tabs",
    "activeTab",
    "scripting",
    "webNavigation",
    "webRequest",
    "notifications",
    "declarativeNetRequest"
  ],
  "host_permissions": [
    "http://localhost:5000/*",
    "http://127.0.0.1:5000/*",
    "http://localhost:3000/*",
    "http://127.0.0.1:3000/*",
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_end"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "overlay.html", 
        "overlay.css", 
        "blocked.html", 
        "blocked-script.js",
        "analyzing.html",
        "analyzing-script.js"
      ],
      "matches": ["<all_urls>"]
    }
  ]
}
